NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# JWT
JWT_SECRET=change_me
JWT_ISSUER=ecommerce-admin
JWT_AUDIENCE=ecommerce-admin
JWT_EXPIRES_IN=8h

# CORS
CORS_ORIGIN=http://localhost:5173

# SMTP (OTP email delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
OTP_FROM_EMAIL=

# OTP (minutes)
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_COOLDOWN_SECONDS=30
OTP_DEBUG_LOG=false

# Inventory
LOW_STOCK_THRESHOLD=5
